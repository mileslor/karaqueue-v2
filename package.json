{
  "name": "karaqueue",
  "version": "1.0.0",
  "description": "本地 WiFi YouTube KTV 點歌系統 | Local WiFi YouTube Karaoke Queue System",
  "main": "main.js",
  "author": "Milestone Technology <info@hkmilestone.com>",
  "license": "MIT",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "dependencies": {
    "express": "^4.18.2",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.milestone.karaqueue",
    "productName": "KaraQueue",
    "copyright": "Copyright © 2025 Milestone Technology",
    "directories": {
      "output": "dist"
    },
    "asar": false,
    "files": [
      "main.js",
      "server.js",
      "public/**/*",
      "playlists/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!dist/**/*"
    ],
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "assets/icon.png",
      "category": "AudioVideo"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.entertainment",
      "identity": null
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "dmg": {
      "title": "KaraQueue ${version}",
      "backgroundColor": "#1a1a2e",
      "window": {
        "width": 540,
        "height": 380
      }
    }
  }
}
